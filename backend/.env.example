# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Postgres (matches docker-compose)
DATABASE_URL=postgresql://events:events@localhost:5432/events_manage?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=events-manage-api
KAFKA_CONSUMER_GROUP=events-manage-consumer

# JWT
JWT_ACCESS_SECRET=change-me-dev-access-secret
JWT_REFRESH_SECRET=change-me-dev-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Sessions
SESSION_TTL_SECONDS=604800

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880
PUBLIC_UPLOAD_PATH=/static
